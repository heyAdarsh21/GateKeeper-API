# Server port
PORT=3000

# Environment: development | production
NODE_ENV=development

# Rate limiter: time window in milliseconds
RATE_LIMIT_WINDOW_MS=60000

# Rate limiter: max requests allowed per window per IP
RATE_LIMIT_MAX_REQUESTS=5

# Pagination: default number of items per page
DEFAULT_PAGE_LIMIT=20

# Pagination: maximum allowed items per page
MAX_PAGE_LIMIT=100

# Validation: maximum number of URLs allowed in a single request body
MAX_URLS_PER_REQUEST=20

# Validation: maximum character length for any single URL
MAX_URL_LENGTH=2048
